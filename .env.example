# =========================================
# CRYPTO QUANT BOT - CONFIGURATION TEMPLATE
# =========================================
#
# ⚠️  IMPORTANT: Copy this file to .env and fill in your actual API keys
#
# Binance Testnet and Mainnet use DIFFERENT API keys!
# Get testnet keys from: https://testnet.binancefuture.com/
# Get mainnet keys from: https://www.binance.com/en/my/settings/api-management
#
# NEVER commit .env to version control!

# =========================================
# MAINNET API KEYS (for LIVE trading)
# =========================================
BINANCE_API_KEY='YOUR_MAINNET_API_KEY_HERE'
BINANCE_API_SECRET='YOUR_MAINNET_API_SECRET_HERE'

# =========================================
# TESTNET API KEYS (for paper trading - DIFFERENT from mainnet!)
# =========================================
BINANCE_TESTNET_API_KEY='YOUR_TESTNET_API_KEY_HERE'
BINANCE_TESTNET_API_SECRET='YOUR_TESTNET_API_SECRET_HERE'

# =========================================
# CURRENT SETTINGS
# =========================================
# Set to True for paper trading, False for live trading
TESTNET=True

# Set to True to simulate orders without executing
DRY_RUN=False

# Enable/disable actual order execution
TRADING_ENABLED=True

# Demo trading mode (simulates fills without real money movement)
DEMO_TRADING=True

# Logging level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# Symbols to trade (comma-separated)
ALLOWED_SYMBOLS=BTC/USDT,ETH/USDT,SOL/USDT,BNB/USDT,XRP/USDT,BTC/USDC,ETH/USDC,SOL/USDC

# Maximum order size in USD
MAX_ORDER_USD=10000

# Global stop loss percentage (of initial investment)
GLOBAL_STOP_LOSS_PCT=50.0

# Exchange market type: future or spot
MARKET_TYPE=future

# Exchange ID (default: binance)
EXCHANGE_ID=binance

# API retry settings
MAX_RETRIES=3
RETRY_DELAY=2

# Futures-only mode (disables spot)
FUTURES_ONLY_MODE=True

# =========================================
# SAFETY CONTROLS
# =========================================
# Block autonomous execution in production (requires human approval)
REQUIRE_HUMAN_APPROVAL=False

# Auto-detect and repair global position wipe (e.g. testnet reset)
ENABLE_GLOBAL_WIPE_DETECTION=True

# Auto-fix zombie orders on startup
AUTO_FIX_ZOMBIES=True

# Strict cleanup: kill manual orders (True) or protect them (False)
STRICT_CLEANUP=False

# Maximum account drawdown percentage before blocking new entries
MAX_ACCOUNT_DRAWDOWN_PERCENT=80.0

# =========================================
# PROOF-LEDGER & PARITY CONTROLS
# =========================================
# Pair parity tolerance: max |virtual - exchange| qty before blocking
PAIR_PARITY_QTY_TOLERANCE=0.002

# Allow forensic/anonymous WS adopt (off by default — proof-only ledger)
ALLOW_FORENSIC_ADOPT=False

# Testnet: when exchange net is 0 but ledger is not, safe-wipe bots
TESTNET_PURGE_PHANTOM_LEDGER=True

# When ledger is flat but exchange still holds size, auto repair
AUTO_REPAIR_ORPHAN_EXCHANGE=False

# One-way: block opposite-direction entry while siblings hold open_qty
ONE_WAY_BLOCK_OPPOSITE_ENTRY=True

# Circuit Breaker: Max quantity allowed to be adopted per bot per cycle
MAX_ADOPTION_QTY_PER_CYCLE=0.5

# Max quantity allowed to be automatically trimmed by OWAY_REPAIR
MAX_OWAY_REPAIR_QTY=50.0

# =========================================
# TECHNICAL INDICATORS
# =========================================
ATR_TIMEFRAME=1h
ATR_PERIODS=14

# =========================================
# MONITORING
# =========================================
METRICS_PORT=9090

# =========================================
# TESTING MODE (bypasses production behavior in unit tests)
# =========================================
TESTING_MODE=False