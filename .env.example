# =========================================
# CRYPTO QUANT BOT - CONFIGURATION TEMPLATE
# =========================================
#
# ⚠️  IMPORTANT: Copy this file to .env and fill in your actual API keys
#
# Binance Testnet and Mainnet use DIFFERENT API keys!
# Get testnet keys from: https://testnet.binancefuture.com/
# Get mainnet keys from: https://www.binance.com/en/my/settings/api-management
#
# NEVER commit .env to version control!

# =========================================
# MAINNET API KEYS (for LIVE trading)
# =========================================
BINANCE_API_KEY='YOUR_MAINNET_API_KEY_HERE'
BINANCE_API_SECRET='YOUR_MAINNET_API_SECRET_HERE'

# =========================================
# TESTNET API KEYS (for paper trading - DIFFERENT from mainnet!)
# =========================================
BINANCE_TESTNET_API_KEY='YOUR_TESTNET_API_KEY_HERE'
BINANCE_TESTNET_API_SECRET='YOUR_TESTNET_API_SECRET_HERE'

# =========================================
# CURRENT SETTINGS
# =========================================
# Set to True for paper trading, False for live trading
USE_TESTNET=True

# Set to True to simulate orders without executing
DRY_RUN=False

# Logging level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# Symbols to trade (comma-separated)
ALLOWED_SYMBOLS=BTC/USDT,ETH/USDT,BNB/USDT

# Maximum order size in USD
MAX_ORDER_USD=10000

# Global stop loss percentage (of initial investment)
GLOBAL_STOP_LOSS_PCT=50.0
